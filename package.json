{
  "name": "smart-todo-action",
  "version": "1.0.37",
  "description": "A  GitHub Action that scans your codebase for inline TODOs, FIXMEs, and BUG comments, and automatically creates GitHub Issues — with support for labels, metadata parsing, and semantic enrichment.",
  "main": "dist/index.js",
  "bin": {
    "todo-action": "dist/main.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepare": "yarn ncc build src/ActionMain.ts -o dist",
    "changelog": "ts-node scripts/generateChangelog.ts",
    "build:dist": "ncc build src/ActionMain.ts -o dist",
    "check-version": "ts-node scripts/checkVersionTag.ts",
    "bump-version": "ts-node scripts/bumpVersion.ts"
  },
  "keywords": [
    "github-action",
    "todo",
    "issues",
    "task-tracking",
    "llm",
    "automation"
  ],
  "author": "Diogo Ribeiro <dfr@esmad.ipp.pt>",
  "license": "MIT",
  "packageManager": "yarn@4.12.0",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^9.0.0",
    "@google/genai": "^1.45.0",
    "@jest/globals": "^30.3.0",
    "@octokit/rest": "^22.0.1",
    "@types/jest": "^30.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.29.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vercel/ncc": "^0.38.4",
    "@vitest/coverage-v8": "^4.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^3.1.1"
  }
}
